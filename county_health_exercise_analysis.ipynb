    "X_vif = df_clean[vif_features].copy()\n",
    "X_vif.insert(0, 'const', 1)  # VIF requires an intercept column\n",
    "\n",
    "vif_df = pd.DataFrame({\n",
    "    'Variable': vif_features,\n",
    "    'VIF': [variance_inflation_factor(X_vif.values, i + 1) for i in range(len(vif_features))]\n",
    "})\n",
    "vif_df"
