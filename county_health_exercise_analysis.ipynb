    "# Variance Inflation Factor: quantifies the multicollinearity warning from Model 3\n",
    "vif_features = ['exercise_access', 'log_income', 'food_env', 'uninsured', 'poverty', 'rural']\n",
    "df_clean['log_income'] = np.log(df_clean['income'])\n",
